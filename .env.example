# ─────────────────────────────────────────────────────────────
# Uriel Maforikan Productions — Virtual Cinema
# Copy to .env.local and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Video host — provider is abstracted behind src/lib/video.
# Supported: mux (default). Swap to "vimeo" | "bunny" when implemented.
VIDEO_PROVIDER=mux
# Mux (Settings → Access Tokens, and a Signing Key for signed playback)
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_SIGNING_KEY_ID=your-mux-signing-key-id
MUX_SIGNING_KEY_PRIVATE=your-mux-signing-private-key-base64
# Mux → Settings → Webhooks → signing secret (for /api/webhooks/mux)
MUX_WEBHOOK_SECRET=your-mux-webhook-secret

# Resend (audience email + premiere invites)
RESEND_API_KEY=re_your_key
RESEND_FROM="Uriel Maforikan Productions <hello@urielmaforikan.org>"
RESEND_AUDIENCE_ID=your-resend-audience-id

# Stripe (giving)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# Payments provider abstraction — "stripe" (default) | "paystack" | "flutterwave"
PAYMENTS_PROVIDER=stripe

# Admin allow-list (comma-separated emails granted /admin access)
ADMIN_EMAILS=hello@urielmaforikan.org
